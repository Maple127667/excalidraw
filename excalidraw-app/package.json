{
  "name": "excalidraw-app",
  "version": "1.0.0",
  "private": true,
  "homepage": ".",
  "main": "electron/main.js",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not ie <= 11",
      "not op_mini all",
      "not safari < 12",
      "not kaios <= 2.5",
      "not edge < 79",
      "not chrome < 70",
      "not and_uc < 13",
      "not samsung < 10"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@excalidraw/random-username": "1.0.0",
    "@sentry/browser": "9.0.1",
    "callsites": "4.2.0",
    "firebase": "11.3.1",
    "i18next-browser-languagedetector": "6.1.4",
    "idb-keyval": "6.0.3",
    "jotai": "2.11.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "socket.io-client": "4.7.2",
    "uqr": "0.1.2",
    "vite-plugin-html": "3.2.2"
  },
  "prettier": "@excalidraw/prettier-config",
  "scripts": {
    "build-node": "node ./scripts/build-node.js",
    "build:app:docker": "cross-env VITE_APP_DISABLE_SENTRY=true vite build",
    "build:app": "cross-env VITE_APP_GIT_SHA=$VERCEL_GIT_COMMIT_SHA cross-env VITE_APP_ENABLE_TRACKING=true vite build",
    "build:version": "node ../scripts/build-version.js",
    "build": "yarn build:app && yarn build:version",
    "start": "yarn && vite",
    "start:production": "yarn build && yarn serve",
    "serve": "npx http-server build -a localhost -p 5001 -o",
    "build:preview": "yarn build && vite preview --port 5000",
    "electron:dev": "concurrently \"cross-env VITE_APP_ELECTRON=true VITE_APP_PORT=3080 vite\" \"wait-on http://localhost:3080 && cross-env NODE_ENV=development node ../node_modules/electron/cli.js .\"",
    "electron:build": "yarn build && node ../node_modules/electron-builder/out/cli/cli.js",
    "electron:build:win": "yarn build && node ../node_modules/electron-builder/out/cli/cli.js --win",
    "electron:build:mac": "yarn build && node ../node_modules/electron-builder/out/cli/cli.js --mac",
    "electron:build:linux": "yarn build && node ../node_modules/electron-builder/out/cli/cli.js --linux"
  },
  "devDependencies": {
    "vite-plugin-sitemap": "0.7.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.excalidraw.app",
    "productName": "Excalidraw",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "build/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon-32x32.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/favicon-32x32.png",
      "category": "public.app-category.graphics-design"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon-32x32.png",
      "category": "Graphics"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/favicon-32x32.png",
      "uninstallerIcon": "public/favicon-32x32.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
